<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.lecturesystem.modules.weeklywork.mapper.WeeklyWorkMapper">

    <resultMap id="WeeklyWorkEntityMap" type="com.example.lecturesystem.modules.weeklywork.entity.WeeklyWorkEntity">
        <id property="id" column="id"/>
        <result property="unitId" column="unit_id"/>
        <result property="userId" column="user_id"/>
        <result property="weekNo" column="week_no"/>
        <result property="status" column="status"/>
        <result property="workPlan" column="work_plan"/>
        <result property="workContent" column="work_content"/>
        <result property="remark" column="remark"/>
        <result property="submitTime" column="submit_time"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <resultMap id="WeeklyWorkListItemMap" type="com.example.lecturesystem.modules.weeklywork.vo.WeeklyWorkListItemVO">
        <id property="id" column="id"/>
        <result property="unitId" column="unit_id"/>
        <result property="userId" column="user_id"/>
        <result property="username" column="username"/>
        <result property="realName" column="real_name"/>
        <result property="weekNo" column="week_no"/>
        <result property="status" column="status"/>
        <result property="workPlan" column="work_plan"/>
        <result property="workContent" column="work_content"/>
        <result property="remark" column="remark"/>
        <result property="submitTime" column="submit_time"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <select id="findByUserIdAndWeekNo" resultMap="WeeklyWorkEntityMap">
        SELECT id, unit_id, user_id, week_no, status, work_plan, work_content, remark, submit_time, create_time
        FROM weekly_work
        WHERE user_id = #{userId}
          AND week_no = #{weekNo}
    </select>

    <select id="findById" resultMap="WeeklyWorkEntityMap">
        SELECT id, unit_id, user_id, week_no, status, work_plan, work_content, remark, submit_time, create_time
        FROM weekly_work
        WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.example.lecturesystem.modules.weeklywork.entity.WeeklyWorkEntity" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO weekly_work (unit_id, user_id, week_no, status, work_plan, work_content, remark)
        VALUES (#{unitId}, #{userId}, #{weekNo}, #{status}, #{workPlan}, #{workContent}, #{remark})
    </insert>

    <update id="updateDraft" parameterType="com.example.lecturesystem.modules.weeklywork.entity.WeeklyWorkEntity">
        UPDATE weekly_work
        SET status = #{status},
            work_plan = #{workPlan},
            work_content = #{workContent},
            remark = #{remark},
            submit_time = NULL
        WHERE id = #{id}
    </update>

    <update id="markSubmitted">
        UPDATE weekly_work
        SET status = 'SUBMITTED',
            submit_time = #{submitTime}
        WHERE id = #{id}
    </update>

    <update id="updateStatus">
        UPDATE weekly_work
        SET status = #{status}
        WHERE id = #{id}
    </update>

    <select id="countDistinctSubmittedUsers" resultType="long">
        SELECT COUNT(DISTINCT w.user_id)
        FROM weekly_work w
        <where>
            <if test="unitId != null">
                w.unit_id = #{unitId}
            </if>
            <if test="weekNo != null and weekNo != ''">
                AND w.week_no = #{weekNo}
            </if>
            <if test="status != null and status != ''">
                AND w.status = #{status}
            </if>
        </where>
    </select>

    <select id="queryList" resultMap="WeeklyWorkListItemMap">
        SELECT w.id,
               w.unit_id,
               w.user_id,
               u.username,
               u.real_name,
               w.week_no,
               w.status,
               w.work_plan,
               w.work_content,
               w.remark,
               w.submit_time,
               w.create_time
        FROM weekly_work w
        INNER JOIN sys_user u ON u.id = w.user_id
        <where>
            <if test="request.unitId != null">
                w.unit_id = #{request.unitId}
            </if>
            <if test="request.weekNo != null and request.weekNo != ''">
                AND w.week_no = #{request.weekNo}
            </if>
            <if test="request.status != null and request.status != ''">
                AND w.status = #{request.status}
            </if>
            <if test="request.userId != null">
                AND w.user_id = #{request.userId}
            </if>
        </where>
        ORDER BY w.week_no DESC, w.create_time DESC, w.id DESC
    </select>
</mapper>
